#!/usr/bin/env bash
# 且曼学院知识网络 pre-commit hook (v1.4)
# 当 stage 中包含 index.html 改动时，自动跑 audit-knowledge-network.js
# 验证数据完整性。失败时阻断 commit。
#
# Exit code 策略：
#   0 → 审计全过，允许提交
#   1 → P0 失败（语法错 / KM 概念未连接释义）→ 阻断
#   2 → P1 失败（aliases / week / cat 字段非法）→ 阻断
#   3 → P2 警告（孤词数 / 反向引用覆盖率）→ 允许通过但警告
#   * → 未知错误 → 阻断
#
# 应急绕过：git commit --no-verify

set -uo pipefail

# ────────────────────────────────────────────────────
# 1. 检查 stage 中是否有 index.html 改动
# ────────────────────────────────────────────────────
STAGED_INDEX=$(git diff --cached --name-only --diff-filter=ACMR | grep -c "^index\.html$" || true)

if [ "$STAGED_INDEX" -eq 0 ]; then
  # 没改 index.html，跳过审计（hook 不应阻断无关 commit）
  exit 0
fi

# ────────────────────────────────────────────────────
# 2. 定位 audit 脚本
# ────────────────────────────────────────────────────
SKILL_AUDIT="$HOME/.codeium/windsurf/skills/qieman-academy-knowledge-network/scripts/audit-knowledge-network.js"

if [ ! -f "$SKILL_AUDIT" ]; then
  echo ""
  echo "⚠️  pre-commit: 找不到 skill audit 脚本"
  echo "   预期路径: $SKILL_AUDIT"
  echo "   跳过自动审计（建议安装 qieman-academy-knowledge-network skill）"
  echo ""
  exit 0
fi

# 检查 node 是否可用
if ! command -v node >/dev/null 2>&1; then
  echo ""
  echo "⚠️  pre-commit: 未找到 node 命令，无法执行审计 → 跳过"
  echo ""
  exit 0
fi

# ────────────────────────────────────────────────────
# 3. 跑审计
# ────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════"
echo "🔍 pre-commit: 检测到 index.html 改动 → 执行知识网络审计"
echo "═══════════════════════════════════════════════════"
echo ""

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
node "$SKILL_AUDIT" --project="$PROJECT_ROOT" 2>&1 | tail -30
audit_exit="${PIPESTATUS[0]}"

echo ""

# ────────────────────────────────────────────────────
# 4. 根据 exit code 决策
# ────────────────────────────────────────────────────
case "$audit_exit" in
  0)
    echo "✅ pre-commit: 审计全部 8 项通过 → 允许提交"
    echo ""
    exit 0
    ;;
  1)
    echo "❌ pre-commit: P0 失败 —— 数据完整性问题"
    echo "   常见原因: JS 语法错误 / KNOWLEDGE_MAP 概念找不到 NH_GLOSSARY 释义"
    echo "   请修复后重新 git commit"
    echo "   应急绕过: git commit --no-verify (仅在确认无误时使用)"
    echo ""
    exit 1
    ;;
  2)
    echo "❌ pre-commit: P1 失败 —— 字段合法性问题"
    echo "   常见原因: aliases 数组重复 / week 越界 / cat 不在允许集"
    echo "   请修复后重新 git commit"
    echo "   应急绕过: git commit --no-verify"
    echo ""
    exit 1
    ;;
  3)
    echo "⚠️  pre-commit: P2 警告 —— 知识网络质量问题（不阻断）"
    echo "   常见原因: 孤词数 > 60 / 反向引用覆盖率 < 90%"
    echo "   建议有空时优化，但 commit 已通过"
    echo ""
    exit 0
    ;;
  *)
    echo "❌ pre-commit: 审计返回未知 exit code = $audit_exit → 阻断 commit"
    echo "   请检查 audit 脚本是否可用"
    echo "   应急绕过: git commit --no-verify"
    echo ""
    exit 1
    ;;
esac
